{
  "mcpServers": {
    "yaitracker": {
      "command": "/path/to/yaitracker",
      "args": ["sidecar"],
      "env": {
        "YAITRACKER_URL": "http://localhost:8080",
        "YAITRACKER_OAUTH_ACCESS_TOKEN": "<access_token from POST /api/v1/auth/token>",
        "YAITRACKER_REPO_ROOT": "/absolute/path/to/workspace"
      }
    }
  }
}
