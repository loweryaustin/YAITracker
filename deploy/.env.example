# deploy/.env.example -- copy to deploy/.env and fill in real values.
# deploy/.env is gitignored and must never be committed.

# SSH host alias (from ~/.ssh/config) for the target server
DEPLOY_HOST=your-ssh-alias

# Absolute path on the remote host where the database directory lives
DEPLOY_DATA_DIR=/path/to/yaitracker-data

# Host port to expose (maps to container port 8080)
DEPLOY_PORT=9080

# Full URL used for post-deploy health checks
DEPLOY_HEALTHCHECK_URL=http://your-host:9080/healthz

# Application secret (minimum 32 characters)
YAITRACKER_SECRET=generate-a-random-secret-here
