#!/usr/bin/env bash
# Enforces conventional commits and requires Refs: YAIT-N (or Refs: none) in the body.
# Bypass: git commit --no-verify

set -euo pipefail

msg_file="${1:?}"
first_line="$(head -n 1 "$msg_file")"

# Merge commits, reverts, and GitHub squash merge summaries
if [[ "$first_line" =~ ^Merge\  ]] ||
   [[ "$first_line" =~ ^Revert\  ]] ||
   [[ "$first_line" =~ ^Merged\ in\  ]]; then
  exit 0
fi

# Conventional commit: type(scope): subject  OR  type: subject
# Optional ! for breaking change in type line
if [[ "$first_line" =~ ^(feat|fix|refactor|test|docs|chore|perf)(\([a-zA-Z0-9._/-]+\))?!?:\ .+ ]]; then
  :
elif [[ "$first_line" =~ ^(feat|fix|refactor|test|docs|chore|perf)!?:\ .+ ]]; then
  :
else
  echo "commit-msg: first line must match conventional commits, e.g." >&2
  echo "  feat(scope): add thing" >&2
  echo "  fix: correct thing" >&2
  echo "got: $first_line" >&2
  exit 1
fi

body="$(tail -n +2 "$msg_file" | sed '/^$/d')"
if ! echo "$body" | grep -qE '^Refs: (YAIT-[0-9]+|none)[[:space:]]*$'; then
  echo "commit-msg: commit body must include a line: Refs: YAIT-N (issue number) or Refs: none" >&2
  echo "  example: Refs: YAIT-42" >&2
  exit 1
fi

exit 0
